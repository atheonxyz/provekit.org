---
const product = ['DOCS', 'GUIDE', 'BENCHMARKS'];
const community = ['TELEGRAM', 'TWITTER', 'GITHUB'];
---

<footer
  style="width:1600px;max-width:100%;padding:48px 24px 24px;display:flex;flex-direction:column;gap:12px;position:relative;overflow:hidden;border-left:1px solid var(--pk-line);border-right:1px solid var(--pk-line);box-sizing:border-box"
>
  <div
    style="display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap"
  >
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      {
        product.map((label) => (
          <a class="pk-chip" href="#" data-todo={label.toLowerCase()}>
            {label}
          </a>
        ))
      }
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      {
        community.map((label) => (
          <a class="pk-chip" href="#" data-todo={label.toLowerCase()}>
            {label}
          </a>
        ))
      }
    </div>
  </div>

  <!-- Giant Provekit wordmark, full-bleed, clipped at the bottom.
       On hover, fades into an ASCII-shader canvas rendering. -->
  <div
    data-ascii-wordmark
    style="width:100%;margin-top:24px;margin-bottom:-32px;position:relative;cursor:pointer;overflow:hidden"
    aria-hidden="true"
  >
    <img
      data-ascii-svg
      src="/figma/wordmark-large-blue.svg"
      alt=""
      loading="lazy"
      decoding="async"
      style="width:100%;display:block;transition:opacity 0.25s ease"
    />
    <canvas
      data-ascii-canvas
      aria-hidden="true"
      style="position:absolute;left:0;top:0;width:100%;height:100%;opacity:0;transition:opacity 0.25s ease;pointer-events:none;display:block"
    >
    </canvas>
  </div>
</footer>

<style is:global>
  .pk-chip {
    display: inline-flex;
    align-items: center;
    padding: 8px 16px;
    border: 1px solid var(--pk-line);
    background: transparent;
    font: 400 18px/1 var(--pk-font-mono);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--pk-ink);
    cursor: pointer;
    text-decoration: none;
    transition:
      background 0.18s ease,
      color 0.18s ease,
      border-color 0.18s ease;
  }
  .pk-chip:hover {
    background: var(--pk-brand);
    color: #fff;
    border-color: var(--pk-brand);
  }
</style>
