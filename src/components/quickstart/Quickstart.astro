---
const rust = `// Define a circuit, prove it, verify it.
use provekit::prelude::*;

fn main() -> Result<()> {
    let circuit = Circuit::compile("circuit.pk")?;
    let proof   = circuit.prove(&Inputs { secret: 42 })?;
    assert!(circuit.verify(&proof)?);
    Ok(())
}`;

const browser = `// Generate a proof in the browser (WASM).
import { Prover } from '@provekit/web';

const prover = await Prover.load('/circuit.wasm');
const proof  = await prover.prove({ secret: 42 });
const ok     = await prover.verify(proof);`;
---

<div class="grid gap-12 py-24 md:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] md:items-start">
  <div class="min-w-0">
    <p class="pk-eyebrow pk-reveal">QUICK START</p>
    <h2 id="quickstart-title" class="pk-h2 pk-reveal mt-4">From install to verified proof.</h2>
    <p class="pk-body pk-reveal mt-6 max-w-md">
      Compile a circuit, prove it, verify it &mdash; in Rust, the CLI, or directly in the browser
      via WebAssembly. The same toolkit, the same API surface, on every target.
    </p>
    <a href="#" class="pk-btn pk-btn--ghost pk-reveal mt-8" data-todo="docs">Read the Docs</a>
  </div>

  <div class="pk-reveal min-w-0 space-y-4">
    <figure class="overflow-hidden rounded-md border border-[color:var(--color-line)] bg-white">
      <figcaption
        class="flex items-center justify-between border-b border-[color:var(--color-line)] px-4 py-3"
      >
        <span class="pk-mono text-xs text-[color:var(--color-mute)]">RUST</span>
        <span class="pk-mono text-xs text-[color:var(--color-mute)]">main.rs</span>
      </figcaption>
      <pre
        class="overflow-x-auto px-5 py-5 font-mono text-sm leading-relaxed text-[color:var(--color-ink)]"><code>{rust}</code></pre>
    </figure>

    <figure class="overflow-hidden rounded-md border border-[color:var(--color-line)] bg-white">
      <figcaption
        class="flex items-center justify-between border-b border-[color:var(--color-line)] px-4 py-3"
      >
        <span class="pk-mono text-xs text-[color:var(--color-mute)]">TYPESCRIPT</span>
        <span class="pk-mono text-xs text-[color:var(--color-mute)]">browser.ts</span>
      </figcaption>
      <pre
        class="overflow-x-auto px-5 py-5 font-mono text-sm leading-relaxed text-[color:var(--color-ink)]"><code>{browser}</code></pre>
    </figure>

    <p class="pk-mono text-[10px] text-[color:var(--color-mute)]">
      Sketch &mdash; see the docs for the full API and circuit DSL.
    </p>
  </div>
</div>
