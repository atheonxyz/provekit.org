---
import Panel from '~/components/panel/Panel.astro';
import ArrowRight from '~/components/icons/ArrowRight.astro';
---

<!-- Decorative pattern strip (hero-bg + grain overlay) -->
<div
  aria-hidden="true"
  style="position:relative;width:1600px;max-width:100%;height:600px;overflow:hidden;background:#fff;border-left:1px solid var(--pk-line);border-right:1px solid var(--pk-line)"
>
  <img
    src="/figma/hero-bg.png"
    alt=""
    loading="eager"
    decoding="async"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block"
  />
  <div
    style="position:absolute;inset:0;background:url('/figma/grain-texture.png') center/cover;opacity:0.18;mix-blend-mode:overlay;pointer-events:none"
  >
  </div>
</div>

<!-- Headline panel -->
<Panel
  tab="INTRODUCING PROVEKIT"
  tabBrand
  titleId="hero-title"
  contentStyle="padding:72px 48px;display:flex;flex-direction:column;gap:48px"
>
  <div class="pk-reveal">
    <h1
      id="hero-title"
      style="margin:0;font:500 72px/80px var(--pk-font-sans);letter-spacing:-0.02em;color:var(--pk-ink);white-space:pre-line"
    >
      {'Client-side zero-knowledge,\nbuilt for the real world'}
    </h1>
    <p
      style="margin:16px 0 0;max-width:655px;font:300 24px/32px var(--pk-font-sans);color:var(--pk-mute)"
    >
      Provekit is a lightweight, modular ZK toolkit designed from the ground up for client-side
      execution.
    </p>
  </div>
  <div class="pk-reveal" style="display:flex;gap:24px;flex-wrap:wrap">
    <a
      href="#"
      class="pk-btn pk-btn--secondary"
      style="height:52px;padding:8px 16px;min-width:208px"
      data-todo="repo"
    >
      VISIT REPO
      <span style="font:400 22px/1 var(--pk-font-mono);letter-spacing:0.02em">{'{ }'}</span>
    </a>
    <a
      href="#"
      class="pk-btn pk-btn--primary"
      style="height:52px;padding:8px 16px;min-width:237px"
      data-todo="docs"
    >
      EXPLORE DOCS
      <ArrowRight />
    </a>
  </div>
</Panel>
