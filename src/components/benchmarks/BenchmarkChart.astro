---
const data = [
  { metric: 'Proving time', toolkit1: 60, toolkit2: 78, provekit: 100 },
  { metric: 'Memory footprint', toolkit1: 70, toolkit2: 65, provekit: 95 },
  { metric: 'Verifier gates', toolkit1: 55, toolkit2: 72, provekit: 88 },
];

const series = [
  { key: 'toolkit1', label: 'Toolkit A', color: 'var(--color-toolkit-1)' },
  { key: 'toolkit2', label: 'Toolkit B', color: 'var(--color-toolkit-2)' },
  { key: 'provekit', label: 'Provekit', color: 'var(--color-toolkit-3)' },
] as const;
---

<figure class="space-y-6" aria-labelledby="bench-chart-label">
  <figcaption id="bench-chart-label" class="sr-only">
    Illustrative benchmark comparison; higher is better. {
      data.map((row) => (
        <span>
          {row.metric}:{' '}
          {series
            .map((s, i) => `${s.label} ${row[s.key]}${i < series.length - 1 ? ', ' : ''}`)
            .join('')}
          .{' '}
        </span>
      ))
    } Numbers are illustrative until full methodology is published.
  </figcaption>

  <div class="pk-mono flex flex-wrap items-center gap-4 text-xs" aria-hidden="true">
    {
      series.map((s) => (
        <span class="inline-flex items-center gap-2">
          <span class="inline-block h-2 w-6 rounded-full" style={`background:${s.color}`} />
          {s.label.toUpperCase()}
        </span>
      ))
    }
  </div>

  <div class="space-y-5" aria-hidden="true">
    {
      data.map((row) => (
        <div>
          <div class="pk-mono mb-2 text-xs text-[color:var(--color-mute)]">
            {row.metric.toUpperCase()}
          </div>
          <div class="space-y-1.5">
            {series.map((s) => (
              <div class="h-3 rounded-full bg-[color:var(--color-line-soft)]">
                <div
                  class="h-full rounded-full"
                  style={`width:${row[s.key]}%;background:${s.color}`}
                />
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>

  <p class="pk-mono text-[10px] text-[color:var(--color-mute)]">
    Illustrative until full methodology is published &mdash; see All Benchmarks.
  </p>
</figure>
