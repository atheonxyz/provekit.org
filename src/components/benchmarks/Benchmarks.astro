---
import BenchmarkChart from './BenchmarkChart.astro';
const points = [
  {
    n: '1.',
    title: 'Proving time',
    body: 'Provekit generates proofs ~36% faster than comparable client-side toolkits on commodity hardware.',
  },
  {
    n: '2.',
    title: 'Memory footprint',
    body: 'A streamlined Rust core keeps the resident set ~24% lighter than the next nearest toolkit.',
  },
  {
    n: '3.',
    title: 'Verification cost',
    body: 'Verifier circuits compile to a fraction of the gate count, keeping cost low on chain and off.',
  },
];
---

<div class="py-24">
  <div class="grid gap-12 md:grid-cols-2 md:items-start">
    <div>
      <p class="pk-eyebrow pk-reveal">BENCHMARKS</p>
      <h2 id="benchmarks-title" class="pk-h2 pk-reveal mt-4">
        A client-side ZK toolkit that excels in every aspect.
      </h2>
      <ol class="pk-reveal mt-10 space-y-8">
        {
          points.map((p) => (
            <li class="grid grid-cols-[auto_1fr] gap-4">
              <span class="pk-mono text-sm text-[color:var(--color-mute)]">{p.n}</span>
              <div>
                <div class="pk-mono text-sm">{p.title}</div>
                <p class="pk-body mt-2 text-base">{p.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
      <a href="#" class="pk-btn pk-btn--primary pk-reveal mt-10" data-todo="benchmarks">
        All Benchmarks
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="pk-reveal rounded-md border border-[color:var(--color-line)] bg-white p-8">
      <BenchmarkChart />
    </div>
  </div>

  <!-- +36% / +24% headline strip -->
  <div class="pk-reveal mt-12 grid w-full grid-cols-1 gap-0 md:grid-cols-2">
    <div
      class="relative flex items-center justify-center overflow-hidden border border-[color:var(--color-line)] bg-white px-6 py-12 md:py-16"
    >
      <span
        class="absolute inset-0 -z-0 block opacity-90"
        style="background: radial-gradient(closest-side at 50% 60%, var(--color-bloom-cyan) 0%, transparent 70%); filter: blur(40px);"
        aria-hidden="true"></span>
      <span class="pk-display relative z-10 text-[clamp(48px,5vw,72px)]"
        ><span class="font-semibold">+36%</span> Faster</span
      >
    </div>
    <div
      class="relative flex items-center justify-center overflow-hidden border border-[color:var(--color-line)] bg-white px-6 py-12 md:border-l-0 md:py-16"
    >
      <span
        class="absolute inset-0 -z-0 block opacity-90"
        style="background: radial-gradient(closest-side at 50% 60%, var(--color-bloom-orange) 0%, transparent 70%); filter: blur(40px);"
        aria-hidden="true"></span>
      <span class="pk-display relative z-10 text-[clamp(48px,5vw,72px)]"
        ><span class="font-semibold">+24%</span> Lighter</span
      >
    </div>
  </div>
</div>
