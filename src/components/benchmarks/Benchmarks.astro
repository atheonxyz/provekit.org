---
import ArrowRight from '~/components/icons/ArrowRight.astro';
import LineChart from '~/components/charts/LineChart.astro';
import BarsChart from '~/components/charts/BarsChart.astro';
import ColumnsChart from '~/components/charts/ColumnsChart.astro';
import { METRICS } from '~/data/benchmarks';

const labels = ['Proving time · Line', 'Memory footprint · Bars', 'Verification cost · Columns'];
const legend = [
  { label: 'TOOLKIT 1', color: '#DE00FF' },
  { label: 'TOOLKIT 2', color: '#E91900' },
  { label: 'PROVEKIT', color: '#0D74FF' },
];
---

<section
  class="pk-bench"
  style="width:1600px;max-width:100%;display:flex"
  aria-labelledby="benchmarks-title"
>
  <!-- LEFT -->
  <div
    style="flex:1 1 0;background:#fff;border:1px solid var(--pk-line);display:flex;flex-direction:column;min-width:0"
  >
    <div class="pk-tab" style="border-top:0;border-left:0">BENCHMARKS</div>
    <div style="padding:108px 48px;display:flex;flex-direction:column;gap:36px">
      <h2
        id="benchmarks-title"
        class="pk-reveal"
        style="margin:0;font:500 64px/72px var(--pk-font-sans);letter-spacing:-0.02em;color:var(--pk-ink);white-space:pre-line"
      >
        {'A client-side ZK toolkit\nthat excels in every aspect'}
      </h2>
      <div
        class="pk-reveal"
        role="tablist"
        aria-label="Benchmark metrics"
        style="display:flex;flex-direction:column;gap:24px"
      >
        {
          METRICS.map((m, i) => (
            <>
              <button
                type="button"
                class="pk-bench-item"
                data-idx={i}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                style="appearance:none;background:transparent;border:0;border-left:3px solid transparent;cursor:pointer;text-align:left;display:flex;flex-direction:column;gap:8px;padding:4px 0 4px 16px;margin-left:-19px;transition:border-color 0.18s ease,color 0.18s ease;user-select:none;color:inherit;font:inherit"
              >
                <span
                  class="pk-bench-num"
                  style="font:500 28px/1 var(--pk-font-sans);transition:color 0.18s ease"
                >
                  {i + 1}.
                </span>
                <span
                  class="pk-bench-title"
                  style="margin:0;font:500 28px/1 var(--pk-font-sans);letter-spacing:-0.02em;transition:color 0.18s ease"
                >
                  {m.title}
                </span>
                <span style="font:300 22px/1.4 var(--pk-font-sans);color:var(--pk-mute-2)">
                  {m.body}
                </span>
              </button>
              {i < METRICS.length - 1 && (
                <div style="border-top:2px solid var(--pk-line)" aria-hidden="true" />
              )}
            </>
          ))
        }
      </div>
      <div>
        <a
          href="/benchmarks"
          class="pk-btn pk-btn--primary pk-reveal"
          style="height:52px;padding:8px 16px;min-width:266px"
        >
          ALL BENCHMARKS
          <ArrowRight />
        </a>
      </div>
    </div>
  </div>

  <!-- RIGHT -->
  <div
    style="flex:1 1 0;background:#fff;border:1px solid var(--pk-line);border-left:0;display:flex;flex-direction:column;justify-content:space-between;min-width:0"
  >
    <div style="padding:72px 48px;display:flex;flex-direction:column;flex:1">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">
        <span
          class="pk-bench-chart-label"
          style="font:400 14px/1 var(--pk-font-mono);letter-spacing:0.08em;text-transform:uppercase;color:var(--pk-mute-2)"
        >
          {labels[0]}
        </span>
      </div>
      <div
        class="pk-reveal"
        style="flex:1;display:flex;flex-direction:column;justify-content:center;position:relative"
      >
        <div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:32px">
          {
            legend.map((s) => (
              <div style="display:inline-flex;align-items:center;gap:8px;padding:8px 16px;border:1px solid var(--pk-line);font:400 18px/1 var(--pk-font-mono);letter-spacing:0.02em;text-transform:uppercase">
                <span
                  style={`width:12px;height:12px;background:${s.color};display:inline-block`}
                  aria-hidden="true"
                />
                {s.label}
              </div>
            ))
          }
        </div>
        <div data-chart="0">
          <LineChart metric={METRICS[0]} />
        </div>
        <div data-chart="1" hidden>
          <BarsChart metric={METRICS[1]} />
        </div>
        <div data-chart="2" hidden>
          <ColumnsChart metric={METRICS[2]} hatchId="pk-col-hatch-landing" />
        </div>
      </div>
    </div>
    {
      METRICS.map((m, i) => (
        <div data-kpis={i} hidden={i !== 0} style="display:flex">
          {m.kpis.map((k, j) => (
            <div
              style={`flex:1;padding:48px 24px;text-align:center;border-top:1px solid var(--pk-line);${j < m.kpis.length - 1 ? 'border-right:1px solid var(--pk-line);' : ''}font:300 48px/1 var(--pk-font-sans);letter-spacing:-0.02em`}
            >
              {k.value}
            </div>
          ))}
        </div>
      ))
    }
  </div>
</section>

<script>
  const root = document.querySelector<HTMLElement>('.pk-bench');
  if (root) {
    const items = root.querySelectorAll<HTMLElement>('[data-idx]');
    const charts = root.querySelectorAll<HTMLElement>('[data-chart]');
    const kpis = root.querySelectorAll<HTMLElement>('[data-kpis]');
    const label = root.querySelector<HTMLElement>('.pk-bench-chart-label');
    const labels = [
      'Proving time · Line',
      'Memory footprint · Bars',
      'Verification cost · Columns',
    ];

    function setActive(idx: number) {
      items.forEach((el, i) => {
        const active = i === idx;
        el.style.borderLeftColor = active ? 'var(--pk-brand)' : 'transparent';
        el.setAttribute('aria-selected', String(active));
        const num = el.querySelector<HTMLElement>('.pk-bench-num');
        const title = el.querySelector<HTMLElement>('.pk-bench-title');
        if (num) num.style.color = active ? 'var(--pk-brand)' : 'var(--pk-ink)';
        if (title) title.style.color = active ? 'var(--pk-brand)' : 'var(--pk-ink)';
      });
      charts.forEach((el, i) => el.toggleAttribute('hidden', i !== idx));
      kpis.forEach((el, i) => el.toggleAttribute('hidden', i !== idx));
      if (label) label.textContent = labels[idx] ?? '';
    }

    items.forEach((el, i) => {
      el.addEventListener('click', () => setActive(i));
      el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          setActive(i);
        }
      });
    });
    setActive(0);
  }
</script>
