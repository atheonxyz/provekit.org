---
interface Props {
  num: string;
  title: string;
  body: string;
  image: string;
  borderColor: string;
}
const { num, title, body, image, borderColor } = Astro.props;
---

<article
  class="pk-reveal"
  style={`flex:1 1 0;max-width:465px;height:722px;border:2px solid ${borderColor};background:#fff;display:flex;flex-direction:column;overflow:hidden;position:relative`}
>
  <!-- Image area -->
  <div style="flex:1;position:relative;overflow:hidden;background:#fff">
    <img
      src={image}
      alt=""
      aria-hidden="true"
      loading="lazy"
      decoding="async"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block"
    />
  </div>
  <!-- Number + title bar -->
  <div style={`display:flex;align-items:stretch;border-top:2px solid ${borderColor}`}>
    <div
      style={`width:69px;height:69px;display:flex;align-items:center;justify-content:center;border-right:1px solid ${borderColor};font:400 24px/1 var(--pk-font-mono);letter-spacing:0.02em`}
    >
      {num}
    </div>
    <h3
      style="flex:1;margin:0;display:flex;align-items:center;padding:0 24px;font:400 24px/1 var(--pk-font-mono);letter-spacing:0.02em;text-transform:uppercase;color:var(--pk-ink)"
    >
      {title}
    </h3>
  </div>
  <!-- Body -->
  <div
    style={`height:220px;padding:48px;border-top:2px solid ${borderColor};font:300 22px/1.4 var(--pk-font-sans);color:#808080;box-sizing:border-box;display:flex;align-items:center`}
  >
    {body}
  </div>
</article>
