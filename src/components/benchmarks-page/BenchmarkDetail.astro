---
import Panel from '~/components/panel/Panel.astro';
import LineChart from '~/components/charts/LineChart.astro';
import BarsChart from '~/components/charts/BarsChart.astro';
import ColumnsChart from '~/components/charts/ColumnsChart.astro';
import { METRICS, DETAIL_EXTRAS } from '~/data/benchmarks';

interface Props {
  index: 0 | 1 | 2;
}
const { index } = Astro.props;
const metric = METRICS[index];
const extra = DETAIL_EXTRAS[metric.key];
const num = String(index + 1).padStart(2, '0');
const headlineKpi = metric.kpis[0]?.value ?? '';
---

<Panel
  tab={`${num} · ${metric.title.toUpperCase()}`}
  titleId={`bench-detail-${index}-title`}
  contentStyle="display:flex;flex-direction:column"
>
  <!-- Header -->
  <div
    style="padding:56px 48px 0;display:flex;justify-content:space-between;align-items:flex-start;gap:48px;flex-wrap:wrap"
  >
    <div style="flex:1 1 0;min-width:0">
      <h2
        id={`bench-detail-${index}-title`}
        class="pk-reveal"
        style="margin:0;font:500 56px/64px var(--pk-font-sans);letter-spacing:-0.02em;color:var(--pk-ink)"
      >
        {metric.title}
      </h2>
      <p
        class="pk-reveal"
        style="margin:16px 0 0;max-width:720px;font:300 20px/1.4 var(--pk-font-sans);color:var(--pk-mute-2)"
      >
        {metric.body}
      </p>
    </div>
    <div
      class="pk-reveal"
      style="padding:16px 24px;border:1px solid var(--pk-brand);font:300 44px/1 var(--pk-font-sans);letter-spacing:-0.02em;color:var(--pk-brand);white-space:nowrap"
    >
      {headlineKpi}
    </div>
  </div>

  <!-- Chart row -->
  <div
    style="padding:48px 48px 56px;display:grid;grid-template-columns:260px 1fr;gap:48px;align-items:start"
  >
    <div style="display:flex;flex-direction:column;gap:20px">
      <div
        style="font:400 13px/1 var(--pk-font-mono);letter-spacing:0.08em;text-transform:uppercase;color:var(--pk-mute-2)"
      >
        Test setup
      </div>
      <ul style="margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:14px">
        {
          extra.notes.map((n) => (
            <li style="font:300 16px/1.45 var(--pk-font-sans);color:var(--pk-mute-2);padding-left:16px;position:relative">
              <span
                style="position:absolute;left:0;top:8px;width:6px;height:6px;background:var(--pk-brand)"
                aria-hidden="true"
              />
              {n}
            </li>
          ))
        }
      </ul>
      <div style="margin-top:8px;display:flex;flex-direction:column;gap:8px">
        <div
          style="font:400 13px/1 var(--pk-font-mono);letter-spacing:0.08em;text-transform:uppercase;color:var(--pk-mute-2)"
        >
          Series
        </div>
        {
          metric.series.map((s) => (
            <div style="display:inline-flex;align-items:center;gap:8px;font:400 14px/1 var(--pk-font-mono);letter-spacing:0.04em">
              <span style={`width:12px;height:12px;background:${s.color}`} aria-hidden="true" />
              {s.label}
            </div>
          ))
        }
      </div>
    </div>
    <div class="pk-reveal" style="min-width:0">
      {metric.chart === 'line' && <LineChart metric={metric} />}
      {metric.chart === 'bars' && <BarsChart metric={metric} />}
      {
        metric.chart === 'columns' && (
          <ColumnsChart metric={metric} hatchId={`pk-col-hatch-detail-${index}`} />
        )
      }
    </div>
  </div>

  <!-- KPI strip -->
  <div style="display:flex;border-top:1px solid var(--pk-line);flex-wrap:wrap">
    {
      extra.extraKpis.map((k, i) => {
        const accent = i === extra.extraKpis.length - 1;
        return (
          <div
            style={`flex:1 1 0;min-width:160px;padding:36px 24px;${i < extra.extraKpis.length - 1 ? 'border-right:1px solid var(--pk-line);' : ''}display:flex;flex-direction:column;gap:8px`}
          >
            <div style="font:400 13px/1 var(--pk-font-mono);letter-spacing:0.08em;text-transform:uppercase;color:var(--pk-mute-2)">
              {k.label}
            </div>
            <div
              style={`font:300 44px/1 var(--pk-font-sans);letter-spacing:-0.02em;color:${accent ? 'var(--pk-brand)' : 'var(--pk-ink)'}`}
            >
              {k.value}
            </div>
          </div>
        );
      })
    }
  </div>
</Panel>
