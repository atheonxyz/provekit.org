---
import Panel from '~/components/panel/Panel.astro';
---

<Panel
  tab="BENCHMARKS"
  tabBrand
  titleId="benchmarks-hero-title"
  contentStyle="padding:72px 48px;display:flex;flex-direction:column;gap:48px"
>
  <div
    style="display:flex;gap:48px;align-items:flex-end;justify-content:space-between;flex-wrap:wrap"
  >
    <div style="flex:1 1 0;min-width:0">
      <div
        class="pk-reveal"
        style="font:400 18px/1 var(--pk-font-mono);letter-spacing:0.08em;text-transform:uppercase;color:var(--pk-mute-2);margin-bottom:24px"
      >
        v0.4.2 · April 2026
      </div>
      <h1
        id="benchmarks-hero-title"
        class="pk-reveal"
        style="margin:0;font:500 64px/72px var(--pk-font-sans);letter-spacing:-0.02em;color:var(--pk-ink);white-space:pre-line"
      >
        {'Provekit, measured\nagainst the field'}
      </h1>
      <p
        class="pk-reveal"
        style="margin:16px 0 0;max-width:720px;font:400 22px/1.4 var(--pk-font-sans);color:var(--pk-mute-2)"
      >
        A reproducible look at how Provekit performs against TOOLKIT 1 and TOOLKIT 2 across proving
        time, memory, and verification cost — measured on commodity client hardware, with the
        dataset and methodology published in full below.
      </p>
    </div>
    <div class="pk-reveal" style="display:flex;gap:12px;flex-shrink:0">
      <a href="/" class="pk-btn pk-btn--secondary" style="height:52px;padding:8px 16px"> ← BACK </a>
      <a
        href="#"
        class="pk-btn pk-btn--primary"
        style="height:52px;padding:8px 16px;min-width:200px"
        data-todo="raw-results"
      >
        RAW RESULTS
        <span style="font:400 22px/1 var(--pk-font-mono);letter-spacing:0.02em">{'{ }'}</span>
      </a>
    </div>
  </div>
</Panel>
